<?xml version="1.0" encoding="UTF-8"?>
<!--
  JPA persistence.xml - exam06 ~ exam10용 퍼시스턴스 단위 정의
  대상 DB: Oracle 19c+
  JPA 버전: 3.1 (Jakarta EE 10)
  구현체: Hibernate 6.6

  접속 정보(URL/username/password)는 소스 코드에서 OS 환경 변수로 읽어
  Persistence.createEntityManagerFactory("단위명", props)의 두 번째 인수로 전달한다.
  따라서 이 파일에는 접속 정보를 기록하지 않는다.
-->
<persistence version="3.1"
    xmlns="https://jakarta.ee/xml/ns/persistence"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
        https://jakarta.ee/xml/ns/persistence/persistence_3_1.xsd">

    <!-- ────────────────────────────────────────────────────────────────────
         exam06: JPA 소개 & EntityManagerFactory / EntityManager
         ──────────────────────────────────────────────────────────────────── -->
    <persistence-unit name="exam06" transaction-type="RESOURCE_LOCAL">
        <class>com.eomcs.advanced.jpa.exam06.Customer</class>
        <exclude-unlisted-classes>true</exclude-unlisted-classes>
        <properties>
            <property name="jakarta.persistence.jdbc.driver"
                      value="oracle.jdbc.OracleDriver"/>
            <property name="hibernate.dialect"
                      value="org.hibernate.dialect.OracleDialect"/>
            <property name="hibernate.show_sql"       value="true"/>
            <property name="hibernate.format_sql"     value="true"/>
            <property name="hibernate.use_sql_comments" value="true"/>
            <property name="hibernate.hbm2ddl.auto"   value="none"/>
        </properties>
    </persistence-unit>

